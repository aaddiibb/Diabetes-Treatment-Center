<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.diabetes.AppointmentBookingController"
      spacing="16"
      styleClass="root-container">

    <padding>
        <Insets top="24" right="60" bottom="24" left="60"/>
    </padding>

    <Label text="Book Appointment" styleClass="title-large"/>

    <VBox spacing="8" styleClass="card">
        <padding>
            <Insets top="16" right="16" bottom="16" left="16"/>
        </padding>
        <Label text="Doctor Name:" styleClass="form-label"/>
        <Label fx:id="doctorNameLabel" text="-" styleClass="subtitle"/>

        <Label text="Specialty:" styleClass="form-label"/>
        <Label fx:id="doctorSpecialtyLabel" text="-" />

        <Label text="Clinic:" styleClass="form-label"/>
        <Label fx:id="doctorClinicLabel" text="-" wrapText="true"/>

        <Label text="Available Days:" styleClass="form-label"/>
        <Label fx:id="doctorAvailabilityLabel" text="-" />
    </VBox>

    <Label text="Patient Notes (optional)" styleClass="form-label"/>
    <TextArea fx:id="patientNotesArea" promptText="Write your symptoms / message..." prefRowCount="4"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="cancelButton" text="Cancel" onAction="#handleCancel" styleClass="secondary-button"/>
        <Button fx:id="bookButton" text="Send Request" onAction="#handleBook" styleClass="primary-button"/>
    </HBox>

</VBox>
