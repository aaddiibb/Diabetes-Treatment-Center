<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.diabetes.DoctorsListController"
      spacing="14"
      styleClass="root-container">

    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button fx:id="backButton" text="← Back" onAction="#handleBack" styleClass="secondary-button"/>
        <Label text="Doctors" styleClass="title-large"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="specialtyFilter" prefWidth="220"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
        <content>
            <VBox fx:id="doctorsContainer" spacing="12">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
            </VBox>
        </content>
    </ScrollPane>

</VBox>
