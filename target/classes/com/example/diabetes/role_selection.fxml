<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.diabetes.RoleSelectionController"
      alignment="CENTER"
      spacing="30"
      styleClass="root-container">

    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>

    <Label text="Diabetes Prediction System" styleClass="title-large"/>

    <Text text="Welcome! Please select your role to continue"
          styleClass="subtitle"
          wrappingWidth="450"
          textAlignment="CENTER"/>

    <VBox spacing="20" alignment="CENTER">
        <Button fx:id="patientButton"
                text="Continue as Patient"
                onAction="#handlePatientSelection"
                styleClass="primary-button"
                prefWidth="300"
                prefHeight="55"/>

        <Button fx:id="doctorButton"
                text="Continue as Doctor"
                onAction="#handleDoctorSelection"
                styleClass="primary-button"
                prefWidth="300"
                prefHeight="55"/>
    </VBox>

    <Text text="WELCOME"
          styleClass="text-small"
          textAlignment="CENTER"/>

</VBox>
