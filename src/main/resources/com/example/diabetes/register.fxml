<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.diabetes.RegisterController"
      alignment="CENTER"
      spacing="16"
      styleClass="root-container">

    <padding>
        <Insets top="30" right="60" bottom="30" left="60"/>
    </padding>

    <Label fx:id="titleLabel" text="Create Account" styleClass="title-large"/>

    <VBox spacing="10" maxWidth="520">
        <Label text="Full Name" styleClass="form-label"/>
        <TextField fx:id="nameField" promptText="Enter your name" styleClass="text-field"/>

        <Label text="Email" styleClass="form-label"/>
        <TextField fx:id="emailField" promptText="Enter your email" styleClass="text-field"/>
        
        <!-- Email Requirements -->
        <VBox spacing="5" style="-fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-padding: 10;">
            <Label text="Email Requirements:" styleClass="form-label" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="gmailCheckLabel" text="✗" style="-fx-font-size: 16; -fx-text-fill: #d32f2f;"/>
                <Label text="Add a valid Gmail" style="-fx-font-size: 11;"/>
            </HBox>
        </VBox>

        <Label text="Phone (optional)" styleClass="form-label"/>
        <TextField fx:id="phoneField" promptText="Enter phone" styleClass="text-field"/>

        <Label text="Password" styleClass="form-label"/>
        <PasswordField fx:id="passwordField" promptText="Password" styleClass="text-field"/>
        
        <!-- Password Requirements -->
        <VBox spacing="5" style="-fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-padding: 10;">
            <Label text="Password Requirements:" styleClass="form-label" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="minLengthCheckLabel" text="✗" style="-fx-font-size: 16; -fx-text-fill: #d32f2f;"/>
                <Label text="At least 8 characters" style="-fx-font-size: 11;"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="capitalLetterCheckLabel" text="✗" style="-fx-font-size: 16; -fx-text-fill: #d32f2f;"/>
                <Label text="Contains at least one capital letter (A-Z)" style="-fx-font-size: 11;"/>
            </HBox>
        </VBox>

        <Label text="Confirm Password" styleClass="form-label"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm password" styleClass="text-field"/>

        <!-- Doctor-only -->
        <VBox fx:id="doctorFieldsBox" spacing="10">
            <Separator/>
            <Label text="Doctor Details" styleClass="subtitle"/>

            <Label text="Specialty" styleClass="form-label"/>
            <TextField fx:id="specialtyField" promptText="e.g., Endocrinologist" styleClass="text-field" style="-fx-text-fill: #00e5ff;"/>

            <Label text="Clinic Address" styleClass="form-label"/>
            <TextField fx:id="clinicField" promptText="Clinic address" styleClass="text-field"/>

            <Label text="Available Days" styleClass="form-label"/>
            <TextField fx:id="availableDaysField" promptText="e.g., Mon,Wed,Fri" styleClass="text-field" style="-fx-text-fill: #00ff88;"/>
        </VBox>

        <Button fx:id="registerButton" text="Create Account" onAction="#handleRegister"
                styleClass="primary-button" prefHeight="42" maxWidth="Infinity">
            <VBox.margin><Insets top="12"/></VBox.margin>
        </Button>

        <HBox alignment="CENTER">
            <Hyperlink fx:id="backLink" text="← Back" onAction="#handleBack" styleClass="hyperlink"/>
        </HBox>
    </VBox>
</VBox>
