<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.diabetes.HealthHistoryController"
            fx:id="mainPane"
            style="-fx-background-color: #2b2b2b;">

    <!-- Top Bar -->
    <top>
        <VBox style="-fx-background-color: #1e1e1e; -fx-border-color: #444444; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Health Metrics History &amp; Tracking"
                       style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #F0F0F0;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="downloadReportBtn" text="📥 Download Report"
                        onAction="#handleDownloadReport"
                        style="-fx-padding: 8 15; -fx-font-size: 12; -fx-text-fill: white;
                               -fx-background-color: #2196F3; -fx-cursor: hand;"/>
                <Button fx:id="backBtn" text="← Back"
                        onAction="#handleBack"
                        style="-fx-padding: 8 15; -fx-font-size: 12; -fx-text-fill: white;
                               -fx-background-color: #f44336; -fx-cursor: hand;"/>
            </HBox>
            <Label fx:id="summaryLabel" text="Loading..."
                   style="-fx-font-size: 11; -fx-text-fill: #BBBBBB; -fx-padding: 10 0 0 0;"/>
        </VBox>
    </top>

    <!-- Center Content -->
    <center>
        <TabPane fx:id="tabPane" style="-fx-background-color: #2b2b2b;">
            <!-- Trends Tab -->
            <Tab text="📊 Trends" closable="false">
                <VBox spacing="10" style="-fx-background-color: #2b2b2b; -fx-padding: 15;">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Chart Type:" style="-fx-text-fill: #F0F0F0;"/>
                        <ComboBox fx:id="chartTypeCombo"
                                  style="-fx-padding: 8; -fx-font-size: 11;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Region VBox.vgrow="ALWAYS"/>
                </VBox>
            </Tab>

            <!-- History Table Tab -->
            <Tab text="📋 History" closable="false">
                <VBox spacing="10" style="-fx-background-color: #2b2b2b; -fx-padding: 15;">
                    <Label text="Prediction History" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #F0F0F0;"/>
                    <TableView fx:id="historyTable" style="-fx-control-inner-background: #333333; -fx-text-fill: #F0F0F0;">
                        <columns>
                            <TableColumn fx:id="dateColumn" text="Date" prefWidth="180"/>
                            <TableColumn fx:id="riskColumn" text="Risk %" prefWidth="80"/>
                            <TableColumn fx:id="levelColumn" text="Level" prefWidth="100"/>
                            <TableColumn fx:id="glucoseColumn" text="Glucose (mg/dL)" prefWidth="120"/>
                            <TableColumn fx:id="bmiColumn" text="BMI (kg/m²)" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Statistics Tab -->
            <Tab text="📈 Statistics" closable="false">
                <VBox spacing="10" style="-fx-background-color: #2b2b2b; -fx-padding: 15;">
                    <Label text="Health Statistics" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #F0F0F0;"/>
                    <GridPane hgap="15" vgap="15">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="5"
                              style="-fx-border-color: #444444; -fx-border-width: 1; -fx-padding: 15;
                                     -fx-background-color: #333333;">
                            <Label text="Glucose Stats" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                            <Label text="Min: Loading..." style="-fx-text-fill: #E0E0E0;"/>
                            <Label text="Max: Loading..." style="-fx-text-fill: #E0E0E0;"/>
                            <Label text="Avg: Loading..." style="-fx-text-fill: #E0E0E0;"/>
                        </VBox>
                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="5"
                              style="-fx-border-color: #444444; -fx-border-width: 1; -fx-padding: 15;
                                     -fx-background-color: #333333;">
                            <Label text="BMI Stats" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
                            <Label text="Min: Loading..." style="-fx-text-fill: #E0E0E0;"/>
                            <Label text="Max: Loading..." style="-fx-text-fill: #E0E0E0;"/>
                            <Label text="Avg: Loading..." style="-fx-text-fill: #E0E0E0;"/>
                        </VBox>
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="5"
                              style="-fx-border-color: #444444; -fx-border-width: 1; -fx-padding: 15;
                                     -fx-background-color: #333333;">
                            <Label text="Blood Pressure Stats" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                            <Label text="Min: Loading..." style="-fx-text-fill: #E0E0E0;"/>
                            <Label text="Max: Loading..." style="-fx-text-fill: #E0E0E0;"/>
                            <Label text="Avg: Loading..." style="-fx-text-fill: #E0E0E0;"/>
                        </VBox>
                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="5"
                              style="-fx-border-color: #444444; -fx-border-width: 1; -fx-padding: 15;
                                     -fx-background-color: #333333;">
                            <Label text="Risk Stats" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #F44336;"/>
                            <Label text="Min: Loading..." style="-fx-text-fill: #E0E0E0;"/>
                            <Label text="Max: Loading..." style="-fx-text-fill: #E0E0E0;"/>
                            <Label text="Avg: Loading..." style="-fx-text-fill: #E0E0E0;"/>
                        </VBox>
                    </GridPane>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
