<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.diabetes.PredictionController"
      spacing="15"
      style="-fx-padding: 20;">

    <Label text="Diabetes Risk Prediction" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>

    <Label text="Please fill in your medical information below. All fields are required." style="-fx-font-size: 12; -fx-text-fill: #555555;"/>

    <!-- Form Fields -->
    <GridPane hgap="10" vgap="10" style="-fx-padding: 10;">
        <columnConstraints>
            <ColumnConstraints prefWidth="150"/>
            <ColumnConstraints prefWidth="200" hgrow="ALWAYS"/>
            <ColumnConstraints prefWidth="150"/>
            <ColumnConstraints prefWidth="200" hgrow="ALWAYS"/>
        </columnConstraints>

        <!-- Row 0 -->
        <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nameField" promptText="Your name" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Age:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <TextField fx:id="ageField" promptText="1-120" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

        <!-- Row 1 -->
        <Label text="Pregnancies:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="pregnanciesField" promptText="Number of pregnancies" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Glucose (mg/dL):" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <TextField fx:id="glucoseField" promptText="Fasting glucose level" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

        <!-- Row 2 -->
        <Label text="Blood Pressure (mmHg):" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="bloodPressureField" promptText="Systolic/Diastolic" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label text="Skin Thickness (mm):" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
        <TextField fx:id="skinThicknessField" promptText="Triceps fold" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

        <!-- Row 3 -->
        <Label text="Insulin (μU/ml):" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="insulinField" promptText="2-hour insulin" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <Label text="BMI (kg/m²):" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
        <TextField fx:id="bmiField" promptText="Body Mass Index" GridPane.columnIndex="3" GridPane.rowIndex="3"/>

        <!-- Row 4 -->
        <Label text="Diabetes Pedigree Function:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="dpfField" promptText="Family history factor" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
    </GridPane>

    <!-- Buttons -->
    <HBox spacing="10" style="-fx-padding: 10 0;">
        <Button fx:id="predictBtn" text="Predict" onAction="#handlePredict" style="-fx-padding: 10 30; -fx-font-size: 12;"/>
        <Button fx:id="clearBtn" text="Clear" onAction="#handleClear" style="-fx-padding: 10 30; -fx-font-size: 12;"/>
        <Button fx:id="backBtn" text="Back" onAction="#handleBack" style="-fx-padding: 10 30; -fx-font-size: 12;"/>
    </HBox>

    <!-- Loading Indicator -->
    <Label fx:id="loadingLabel" text="⏳ Processing prediction... Please wait." 
            style="-fx-text-fill: #3498DB; -fx-font-size: 12;" visible="false"/>

    <!-- Result Container -->
    <VBox fx:id="resultContainer" spacing="10" style="-fx-padding: 15;" visible="false"/>
</VBox>
