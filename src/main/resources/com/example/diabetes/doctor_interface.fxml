<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.diabetes.DoctorInterfaceController"
      alignment="CENTER"
      spacing="16"
      styleClass="root-container">

    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>

    <Label fx:id="titleLabel" text="Doctor Dashboard" styleClass="title-large"/>
    <Label text="Manage your appointment requests and schedules." styleClass="subtitle"/>

    <Button fx:id="appointmentsButton"
            text="View Appointments"
            onAction="#handleAppointments"
            styleClass="primary-button"
            prefWidth="260" prefHeight="50"/>

    <Button text="Logout"
            onAction="#handleLogout"
            styleClass="secondary-button"
            prefWidth="200"/>

</VBox>
