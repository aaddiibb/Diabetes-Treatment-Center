<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.diabetes.PatientDashboardController"
      alignment="CENTER"
      spacing="16"
      styleClass="root-container">

    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>

    <Label fx:id="titleLabel" text="Patient Dashboard" styleClass="title-large"/>
    <Label text="Welcome! What would you like to do?" styleClass="subtitle"/>

    <Button fx:id="bookAppointmentButton"
            text="Book Appointment"
            onAction="#handleBookAppointment"
            styleClass="primary-button"
            prefWidth="260" prefHeight="50"/>

    <Button fx:id="myAppointmentsButton"
            text="My Appointments"
            onAction="#handleMyAppointments"
            styleClass="primary-button"
            prefWidth="260" prefHeight="50"/>

    <Button fx:id="predictionButton"
            text="Start Prediction"
            onAction="#handleStartPrediction"
            styleClass="primary-button"
            prefWidth="260" prefHeight="50"/>

    <Button fx:id="healthHistoryButton"
            text="📊 Health Metrics History"
            onAction="#handleViewHealthHistory"
            styleClass="primary-button"
            prefWidth="260" prefHeight="50"/>

    <Button text="Logout"
            onAction="#handleLogout"
            styleClass="secondary-button"
            prefWidth="200"/>

</VBox>
